rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read site content (public website)
    match /site_content/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Anyone can read partners (public website)
    match /partners/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Anyone can read and write analytics
    match /analytics/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
